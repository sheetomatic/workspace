# Neon / Postgres (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Direct connection for Prisma migrations (Neon: use unpooled host)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
CRON_SECRET="generate-a-random-cron-secret"
NEXTAUTH_URL="http://localhost:3000"
# Apex marketing site (used for subdomain parsing and apex redirects)
NEXT_PUBLIC_SITE_URL="https://sheetomatic.com"
NEXT_PUBLIC_ROOT_DOMAIN="sheetomatic.com"
# Share auth sessions across app / ai / tenant subdomains (production only)
# AUTH_COOKIE_DOMAIN=".sheetomatic.com"

# --- Task Delegation APIs (workspace /app/tasks) ---

# OpenAI: multilingual voice/text in, English task fields out
OPENAI_API_KEY=""
# OPENAI_TASK_MODEL="gpt-4o-mini"
# OPENAI_WHISPER_MODEL="whisper-1"
# Max task AI calls (transcribe + parse) per org per day
# TASK_AI_DAILY_ORG_LIMIT="200"
# Voice uses translation to English by default; set OPENAI_WHISPER_OUTPUT=original to keep spoken language

# --- WhatsApp providers (per workspace in Settings, or platform env for primary workspace) ---
# WHATSAPP_PROVIDER="sheetomatic"   # sheetomatic | messageautosender

# Sheetomatic WhatsApp Integration API — send messages + manage templates (per customer account)
# Portal: https://wa.sheetomatic.com  (formerly wa.redlava.in / RedLava)
# Docs: https://wa.sheetomatic.com/Integrations/ApiDocumentation
# Create key: https://wa.sheetomatic.com/Integrations/ListApikey
REDLAVA_API_KEY=""
# Sheetomatic WhatsApp Reseller API — list customers, phones, wallet (reseller account only)
# Docs: https://wa.sheetomatic.com/ApiDocumentation
REDLAVA_RESELLER_API_KEY=""
# Copy Phone ID from Connected accounts or pick from Settings when reseller key is set:
# https://wa.sheetomatic.com/ConnectedAccount
REDLAVA_PHONE_ID=""
# Sheetomatic WhatsApp portal (wa.sheetomatic.com)
REDLAVA_API_BASE_URL="https://wa.sheetomatic.com/api/v1"
# Customer portal links always use https://wa.sheetomatic.com (NEXT_PUBLIC_REDLAVA_DASHBOARD_URL is ignored).
REDLAVA_SIGNUP_ACCOUNT_ID="69ba66e24e68ba4764253829"
# REDLAVA_SEND_ENDPOINT="/whatsapp/meta/sendMessage"
# REDLAVA_TEMPLATE_SUBMIT_ENDPOINT="/messageTemplate/create"
# REDLAVA_TEMPLATE_LIST_ENDPOINT="/messageTemplate/getTemplates"
# REDLAVA_TEMPLATE_SYNC_ENDPOINT="/whatsapp/syncTemplatesFromMeta"

# Message Auto Sender — WhatsApp Web automation (alternative provider)
# Portal: https://app.messageautosender.com
# API docs: https://app.messageautosender.com/swagger-ui/4.1.3/index.html (login required)
MAS_API_BASE_URL="https://app.messageautosender.com/api/v1"
# Platform reseller key for Scan QR (channel/status API). Not stored per workspace.
# MAS_RESELLER_API_KEY=""
MAS_USERNAME=""
MAS_PASSWORD=""

# Optional legacy Meta vars — not required when using Sheetomatic WhatsApp
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_BUSINESS_ID=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_FALLBACK_PHONE="919685788980"
# Test recipient for Settings → Send test message (personal mobile, not business line)
WHATSAPP_TEST_PHONE="919329103106"
# Task assignment WhatsApp template (Meta UTILITY, language en — required for new assignees)
WHATSAPP_TASK_ASSIGNMENT_TEMPLATE=assign_task_new
WHATSAPP_TASK_ASSIGNMENT_TEMPLATE_LANGUAGE=en
# Positional variables: {{1}}=assignee name, {{2}}=title, {{3}}=description, {{4}}=due date
# Template includes static URL button "Update Task" → https://sheetomatic.com/app/tasks (no send-time button params)

# --- WhatsApp Task Delegation Bot (inbound webhook) ---
# Production webhook URL: https://sheetomatic.com/api/webhooks/whatsapp
# WHATSAPP_WEBHOOK_VERIFY_TOKEN="pick-a-random-verify-string"
# META_APP_SECRET=""                    # Meta app secret (Basic settings → Show)
# WHATSAPP_DEFAULT_ORG_SLUG="sheetomatic-technologies"
# For voice notes: set metaAccessToken in Channels settings OR WHATSAPP_ACCESS_TOKEN globally

# Email: task assignment, alerts, password reset, team invites (Resend)
# 1. Create account at https://resend.com
# 2. Verify your domain (e.g. sheetomatic.com) or use onboarding@resend.dev for testing
# 3. Add both vars to Vercel Production:
# RESEND_API_KEY="re_..."
# TASK_EMAIL_FROM="Sheetomatic <notifications@sheetomatic.com>"

# Production (Vercel): use Postgres - SQLite file DB does not persist on serverless
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sheetomatic?sslmode=require"

# --- Scale (~500 concurrent workspace users) ---
# Use Neon pooler URL (host contains -pooler), not direct, for serverless.
# Dev: omit or raise limit (default in code is 10). Production: 5 is safe with pooler.
# DATABASE_CONNECTION_LIMIT="5"
# DATABASE_POOL_TIMEOUT="30"
# Recommended production: Vercel Pro + Neon Scale (2+ CU). See src/lib/scale.ts tunables.

# Optional: Google sign-in (production)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Dashboard data from Google Sheets (/app, Settings) ---
# Create a Google Cloud service account with Sheets API enabled.
# Share your spreadsheet with the service account email (Viewer).
#
# Option A: full JSON on one line
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON='{"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}'
#
# Option B: split credentials
# GOOGLE_SHEETS_CLIENT_EMAIL="your-sa@project.iam.gserviceaccount.com"
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Spreadsheet ID (or set per workspace in Settings > Google Sheets)
# GOOGLE_SHEETS_SPREADSHEET_ID=""
# Per-org override by slug, e.g. acme-manufacturing:
# GOOGLE_SHEETS_ID_ACME_MANUFACTURING=""
#
# Required tabs: Metrics, FollowUps, Payments, Approvals (see Settings for column layout)
# WhatsApp CRM export (/ai/app/contacts → Sync to Sheet) writes a "WA CRM" tab in the same spreadsheet.
#
# Lead capture Google Form (WhatsApp AI sends this instead of asking name/email in chat)
# DEFAULT_LEAD_CAPTURE_GOOGLE_FORM_URL="https://forms.gle/KWSDZty3x4vkgbwX6"
#
# Form responses sheet (bot checks "Responses" tab and acknowledges by name after submit)
# LEAD_CAPTURE_FORM_RESPONSES_SHEET_URL="https://docs.google.com/spreadsheets/d/1uXA3TsZrT9uZNR3fiooNzBKFRYGrxt_1ydJdyJEt11Y/edit?gid=1019902152"
# LEAD_CAPTURE_FORM_RESPONSES_TAB="Responses"
