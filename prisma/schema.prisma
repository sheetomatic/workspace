generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum WorkspaceModule {
  TASKS
  HR
  APPROVALS
  REPORTS
  CASES
  FMS
}

enum FmsFormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  ENUM
  ENUM_LIST
  DATE
  DATETIME
  EMAIL
  PHONE
  FILE
}

enum FmsFormStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FmsTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FmsDesignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FmsInstanceStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FmsStepStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum FmsSlaType {
  NONE
  TAT_CALENDAR_DAYS
  TAT_WORKING_HOURS
  SPECIFIC_TIME
  LEAD_TIME_MINUS
}

enum OrganizationStatus {
  ONBOARDING
  ACTIVE
}

enum WorkspaceLinkType {
  GOOGLE_SHEET
  LOOKER_STUDIO
  APPSHEET
  WHATSAPP
  GOOGLE_FORM
  OTHER
}

model Organization {
  id              String                   @id @default(cuid())
  name            String
  slug            String                   @unique
  industry        String?
  googleSheetId   String?
  googleSheetGid  String?
  legalSheetTab   String?
  legalSheetHeaderRow Int @default(2)
  legalSheetDataStartRow Int @default(3)
  status          OrganizationStatus       @default(ONBOARDING)
  isPrimary       Boolean                  @default(false)
  memberships     Membership[]
  links           WorkspaceLink[]
  kpis            WorkspaceKpi[]
  metricCards     WorkspaceMetricCard[]
  followUps       WorkspaceFollowUp[]
  pendingPayments WorkspacePendingPayment[]
  attentionItems  WorkspaceAttentionItem[]
  approvals       WorkspaceApproval[]
  invitations     Invitation[]
  tasks           DelegatedTask[]
  whatsappTemplates WhatsAppTemplate[]
  whatsappSettings  WorkspaceWhatsAppSettings?
  whatsappInboundEvents WhatsAppInboundEvent[]
  waContacts        WaContact[]
  waContactFollowUps WaContactFollowUp[]
  waConversations   WaConversation[]
  waMessages        WaMessage[]
  aiKnowledgeItems  AiKnowledgeItem[]
  hrSettings        WorkspaceHrSettings?
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]
  payrollRuns       PayrollRun[]
  fieldCheckIns     FieldCheckIn[]
  fieldVisits       FieldVisit[]
  jobOpenings       JobOpening[]
  candidates        Candidate[]
  legalCases        LegalCase[]
  legalCaseDocuments LegalCaseDocument[]
  legalCaseImportBackup LegalCaseImportBackup?
  notificationSettings UserNotificationSettings[]
  taskAiSettings    WorkspaceTaskAiSettings?
  taskAiUsageEvents TaskAiUsageEvent[]
  aiReplySettings   WorkspaceAiReplySettings?
  aiReplyUsageEvents AiReplyUsageEvent[]
  fmsForms          FmsForm[]
  fmsTemplates      FmsTemplate[]
  fmsFlowDesigns    FmsFlowDesign[]
  fmsInstances      FmsInstance[]
  fmsFormSubmissions FmsFormSubmission[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model LegalCase {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fileNumber     String
  mccNumber      String?
  caseRef        String
  applicant      String?
  nonApplicant   String?
  category       String?
  caseStage      String?
  fileStatus     String?
  court          String?
  company        String?
  coAdvocate     String?
  prevDate       String?
  nextDate       String?
  remarks        String?
  amdCcStatus    String?
  fNo            String?
  clientAdvance  String?
  caseFiled      String?
  signingDate    String?
  s2Responsible  String?
  s3Responsible  String?
  s4Responsible  String?
  s5Responsible  String?
  s6Responsible  String?
  s7Responsible  String?
  sectionData    Json         @default("{}")
  documents      LegalCaseDocument[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, caseRef])
  @@index([organizationId, fileNumber])
  @@index([organizationId, fileStatus])
  @@index([organizationId, caseStage])
  @@index([organizationId, applicant])
}

model LegalCaseImportBackup {
  organizationId   String       @id
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseCount        Int
  sourceFilename   String?
  payload          Bytes
  createdAt        DateTime     @default(now())
}

model LegalCaseDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseId         String
  legalCase      LegalCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  section        Int
  category       String
  displayName    String
  fileName       String
  mimeType       String
  fileSize       Int
  data           Bytes
  uploadedById   String
  uploadedBy     User         @relation("LegalCaseDocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([caseId, section, category])
  @@index([organizationId])
}

enum AiKnowledgeType {
  FAQ
  DOCUMENT
  WEBSITE
  YOUTUBE_CHANNEL
}

enum AiKnowledgeStatus {
  ACTIVE
  ARCHIVED
}

model AiKnowledgeItem {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           AiKnowledgeType
  title          String
  question       String?
  content        String
  sourceUrl      String?
  status         AiKnowledgeStatus  @default(ACTIVE)
  lastSyncedAt   DateTime?
  createdById    String
  createdBy      User               @relation("AiKnowledgeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId, type, status])
  @@index([organizationId, status])
}

model DelegatedTask {
  id                     String         @id @default(cuid())
  organizationId         String
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                  String
  instructions           String?
  status                 TaskStatus     @default(PENDING)
  priority               TaskPriority   @default(MEDIUM)
  department             TaskDepartment @default(GENERAL)
  category               String?
  frequency              TaskFrequency  @default(ONCE)
  recurrenceWeeklyDays   String?
  recurrenceMonthDay     Int?
  isRecurring            Boolean        @default(false)
  seriesId               String?
  occurrenceNumber       Int            @default(1)
  nextOccurrenceAt       DateTime?
  remindViaEmail         Boolean        @default(false)
  remindViaWhatsApp      Boolean        @default(false)
  emailAssignmentSentAt  DateTime?
  whatsappAssignmentSentAt DateTime?
  whatsappAssignmentError  String?
  emailReminderSentAt    DateTime?
  whatsappReminderSentAt DateTime?
  dueAt                  DateTime
  assigneeUserId         String
  assignee               User           @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  createdById            String
  createdBy              User           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  completedAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  attachments            TaskAttachment[]
  requests               TaskRequest[]

  @@index([organizationId, status])
  @@index([organizationId, assigneeUserId])
  @@index([organizationId, dueAt])
  @@index([organizationId, status, dueAt])
  @@index([organizationId, seriesId])
}

model RateLimitBucket {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

enum WhatsAppTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

model WhatsAppTemplate {
  id               String                   @id @default(cuid())
  organizationId   String
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  category         WhatsAppTemplateCategory
  language         String                   @default("en")
  body             String
  variables        Json                     @default("[]")
  status           WhatsAppTemplateStatus   @default(PENDING)
  externalId       String?
  rejectionReason  String?
  submittedAt      DateTime                 @default(now())
  approvedAt       DateTime?
  createdById      String
  createdBy        User                     @relation("WhatsAppTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([organizationId, name, language])
  @@index([organizationId, status])
}

enum WhatsAppProvider {
  SHEETOMATIC
  MESSAGEAUTOSENDER
}

model WorkspaceWhatsAppSettings {
  organizationId    String             @id
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessPhone     String?
  whatsappProvider  WhatsAppProvider   @default(SHEETOMATIC)
  redlavaApiKey     String?
  redlavaPhoneId    String?            @unique
  masUsername       String?
  masPassword       String?
  masApiKey         String?
  metaAccessToken   String?
  metaWabaId        String?
  metaBusinessId    String?
  botLiveAt         DateTime?
  lastInboundAt     DateTime?
  updatedAt         DateTime           @updatedAt
}

enum TaskAiRoute {
  PARSE
  TRANSCRIBE
}

model WorkspaceTaskAiSettings {
  organizationId String       @id
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dailyLimit     Int          @default(200)
  enabled        Boolean      @default(true)
  updatedAt      DateTime     @updatedAt
}

model TaskAiUsageEvent {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  route            TaskAiRoute
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  audioBytes       Int          @default(0)
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model WorkspaceAiReplySettings {
  organizationId String       @id
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dailyLimit     Int          @default(300)
  enabled        Boolean      @default(true)
  updatedAt      DateTime     @updatedAt
}

model AiReplyUsageEvent {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  handoff          Boolean      @default(false)
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model WhatsAppInboundEvent {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  externalId     String        @unique
  fromPhone      String
  messageType    String
  status         String        @default("received")
  error          String?
  taskId         String?
  processedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}

enum WaConversationStatus {
  OPEN
  CLOSED
}

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaPipelineStage {
  NEW
  QUALIFIED
  DEMO_BOOKED
  WON
  LOST
}

enum WaLeadCaptureStep {
  PENDING
  FORM
  NAME
  EMAIL
  CITY
  REQUIREMENT
  COMPLETE
}

model WaContact {
  id                     String             @id @default(cuid())
  organizationId         String
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phone                  String
  name                   String?
  email                  String?
  city                   String?
  requirementDescription String?
  intent                 String?
  source                 String             @default("whatsapp")
  pipelineStage          WaPipelineStage    @default(NEW)
  leadCaptureStep        WaLeadCaptureStep  @default(PENDING)
  leadCaptureComplete    Boolean            @default(false)
  googleFormAckSentAt    DateTime?
  tags                   Json               @default("[]")
  notes                  String?
  assignedToId   String?
  assignedTo     User?           @relation("WaContactAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  nextFollowUpAt DateTime?
  lastMessageAt  DateTime?
  unreadCount    Int             @default(0)
  aiEnabled      Boolean         @default(true)
  conversations  WaConversation[]
  followUps      WaContactFollowUp[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, phone])
  @@index([organizationId, lastMessageAt])
  @@index([organizationId, pipelineStage])
  @@index([organizationId, assignedToId])
  @@index([organizationId, nextFollowUpAt])
}

model WaContactFollowUp {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId       String
  contact         WaContact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assigneeUserId  String?
  assignee        User?        @relation("WaFollowUpAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  scheduledAt     DateTime
  completedAt     DateTime?
  notes           String?
  reminderNote    String?
  createdByUserId String?
  createdBy       User?        @relation("WaFollowUpCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, scheduledAt])
  @@index([contactId])
  @@index([assigneeUserId, scheduledAt])
}

model WaConversation {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        WaContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status         WaConversationStatus @default(OPEN)
  aiHandled      Boolean              @default(false)
  preview        String?
  lastMessageAt  DateTime?
  messages       WaMessage[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId, lastMessageAt])
  @@index([contactId])
}

model WaMessage {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   WaConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  externalId     String?            @unique
  direction      WaMessageDirection
  body           String
  messageType    String             @default("text")
  sentByUserId   String?
  sentBy         User?              @relation("WaMessageSender", fields: [sentByUserId], references: [id], onDelete: SetNull)
  aiGenerated    Boolean            @default(false)
  aiConfidence   Float?
  aiSourceTitles Json?
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
}

enum MetricTone {
  DEFAULT
  WARNING
  SUCCESS
}

model WorkspaceMetricCard {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  value          String
  tone           MetricTone   @default(DEFAULT)
  actionLabel    String       @default("Update")
  actionHref     String?
  minRole        Role         @default(VIEWER)
  sortOrder      Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model WorkspaceFollowUp {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientName     String
  followUpAt     DateTime
  remarks        String?
  minRole        Role         @default(STAFF)
  assigneeUserId String?
  assignee       User?        @relation("FollowUpAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  sortOrder      Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([assigneeUserId])
}

model WorkspacePendingPayment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientName     String
  amount         String
  dueAt          DateTime
  minRole        Role         @default(STAFF)
  sortOrder      Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model WorkspaceKpi {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  value          String
  icon           String       @default("trending")
  minRole        Role         @default(VIEWER)
  sortOrder      Int          @default(0)
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model WorkspaceAttentionItem {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  count            Int
  minRole          Role         @default(STAFF)
  assigneeUserId   String?
  assignee         User?        @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  sortOrder        Int          @default(0)
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([assigneeUserId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REVISION_REQUESTED
  EXTENSION_REQUESTED
  HELP_REQUESTED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskDepartment {
  OPERATIONS
  SALES
  ACCOUNTS
  ADMIN
  GENERAL
}

enum TaskFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         DelegatedTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  fileSize     Int
  data         Bytes
  createdAt    DateTime @default(now())

  @@index([taskId])
}

enum TaskRequestType {
  REVISION
  EXTENSION
  HELP
}

enum TaskRequestStatus {
  OPEN
  APPROVED
  REJECTED
  RESOLVED
}

model TaskRequest {
  id             String            @id @default(cuid())
  organizationId String
  taskId         String
  task           DelegatedTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type           TaskRequestType
  status         TaskRequestStatus @default(OPEN)
  message        String?
  proposedDueAt  DateTime?
  requestedById  String
  requestedBy    User              @relation("TaskRequestRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  resolvedById   String?
  resolvedBy     User?             @relation("TaskRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([taskId, status])
}

model WorkspaceApproval {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  department     String
  status         ApprovalStatus @default(PENDING)
  pendingSince   DateTime       @default(now())
  minRole        Role           @default(MANAGER)
  reviewNote     String?
  reviewedById   String?
  reviewedBy     User?          @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  sheetRowKey    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, status])
  @@unique([organizationId, sheetRowKey])
}

model WorkspaceLink {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           WorkspaceLinkType
  label          String
  url            String
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
}

model User {
  id                   String                   @id @default(cuid())
  name                 String?
  phone                String?
  email                String                   @unique
  emailVerified        DateTime?
  passwordHash         String?
  image                String?
  isSuperAdmin         Boolean                  @default(false)
  accounts             Account[]
  sessions             Session[]
  memberships          Membership[]
  invitationsSent      Invitation[]             @relation("InvitationSender")
  reviewedApprovals    WorkspaceApproval[]      @relation("ApprovalReviewer")
  assignedAttention    WorkspaceAttentionItem[]
  assignedFollowUps    WorkspaceFollowUp[]      @relation("FollowUpAssignee")
  assignedTasks        DelegatedTask[]          @relation("TaskAssignee")
  createdTasks         DelegatedTask[]          @relation("TaskCreator")
  taskAttachments      TaskAttachment[]         @relation("TaskAttachmentUploader")
  taskRequestsMade     TaskRequest[]            @relation("TaskRequestRequester")
  taskRequestsResolved TaskRequest[]            @relation("TaskRequestResolver")
  whatsappTemplates    WhatsAppTemplate[]       @relation("WhatsAppTemplateCreator")
  assignedWaContacts   WaContact[]              @relation("WaContactAssignee")
  assignedWaFollowUps  WaContactFollowUp[]      @relation("WaFollowUpAssignee")
  createdWaFollowUps   WaContactFollowUp[]      @relation("WaFollowUpCreator")
  waMessagesSent       WaMessage[]              @relation("WaMessageSender")
  aiKnowledgeCreated   AiKnowledgeItem[]        @relation("AiKnowledgeCreator")
  attendanceRecords    AttendanceRecord[]       @relation("AttendanceUser")
  attendanceMarked     AttendanceRecord[]       @relation("AttendanceMarker")
  leaveRequests        LeaveRequest[]           @relation("LeaveRequester")
  leaveReviews         LeaveRequest[]           @relation("LeaveReviewer")
  fieldCheckIns        FieldCheckIn[]
  fieldVisitsAssigned  FieldVisit[]             @relation("FieldVisitAssignee")
  candidatesOwned      Candidate[]              @relation("CandidateOwner")
  legalCaseDocuments   LegalCaseDocument[]      @relation("LegalCaseDocumentUploader")
  notificationSettings UserNotificationSettings[]
  taskAiUsageEvents    TaskAiUsageEvent[]
  fmsFormsCreated      FmsForm[]                @relation("FmsFormCreator")
  fmsTemplatesCreated  FmsTemplate[]            @relation("FmsTemplateCreator")
  fmsFormSubmissions   FmsFormSubmission[]      @relation("FmsFormSubmitter")
  fmsStepsOwned        FmsStepState[]           @relation("FmsStepOwner")
  fmsStepsCompleted    FmsStepState[]           @relation("FmsStepCompleter")
  fmsStepDefaultOwner  FmsTemplateStep[]        @relation("FmsStepDefaultOwner")
  fmsStepAttachments   FmsStepAttachment[]      @relation("FmsStepAttachmentUploader")
  fmsFlowDesignsCreated FmsFlowDesign[]         @relation("FmsFlowDesignCreator")
  fmsFlowDesignsApproved FmsFlowDesign[]        @relation("FmsFlowDesignApprover")
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
}

model UserNotificationSettings {
  id                 String       @id @default(cuid())
  userId             String
  organizationId     String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseDueDateAlert   Boolean      @default(true)
  caseOverdueAlert   Boolean      @default(true)
  taskDueDateAlert   Boolean      @default(true)
  taskOverdueAlert   Boolean      @default(true)
  alertDaysBefore    Int          @default(1)
  alertViaEmail      Boolean      @default(true)
  alertViaWhatsApp   Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  role           Role         @default(STAFF)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  token          String       @unique
  invitedById    String
  invitedBy      User         @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([email, organizationId])
  @@index([organizationId])
}

model Membership {
  id                 String              @id @default(cuid())
  role               Role                @default(STAFF)
  department         TaskDepartment?
  designation        String?
  isDepartmentHead   Boolean             @default(false)
  reportingManagerId String?
  reportingManager   Membership?         @relation("MembershipReportsTo", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      Membership[]        @relation("MembershipReportsTo")
  attendanceWorkMode AttendanceWorkMode  @default(OFFICE)
  geoFenceRequired   Boolean             @default(false)
  faceRequired       Boolean             @default(false)
  staffCode          String?
  modules            WorkspaceModule[]   @default([])
  userId             String
  organizationId     String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, isDepartmentHead])
  @@index([reportingManagerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AttendanceMethod {
  WEB
  MOBILE
  GEO
  BIOMETRIC
  FACE
}

enum AttendanceDayStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum AttendanceWorkMode {
  OFFICE
  FIELD
  HYBRID
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  COMP_OFF
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
}

enum FieldVisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model WorkspaceHrSettings {
  organizationId       String       @id
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  officeLat            Float?
  officeLng            Float?
  geoFenceRadiusM      Int          @default(200)
  workStartTime        String       @default("09:30")
  workEndTime          String       @default("18:30")
  faceRecognitionEnabled Boolean    @default(false)
  fieldTrackingEnabled Boolean      @default(true)
  updatedAt            DateTime     @updatedAt
}

model AttendanceRecord {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User                @relation("AttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  workDate        DateTime            @db.Date
  checkInAt       DateTime?
  checkOutAt      DateTime?
  status          AttendanceDayStatus @default(PRESENT)
  method          AttendanceMethod    @default(WEB)
  geoLat          Float?
  geoLng          Float?
  geoFenceOk      Boolean?
  faceVerified    Boolean             @default(false)
  notes           String?
  markedById      String?
  markedBy        User?               @relation("AttendanceMarker", fields: [markedById], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([organizationId, userId, workDate])
  @@index([organizationId, workDate])
}

model LeaveBalance {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  leaveType      LeaveType
  balanceDays    Float        @default(0)
  usedDays       Float        @default(0)
  year           Int
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId, leaveType, year])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType      LeaveType
  startDate      DateTime           @db.Date
  endDate        DateTime           @db.Date
  days           Float
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedBy     User?              @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, userId])
}

model PayrollRun {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime         @db.Date
  periodEnd      DateTime         @db.Date
  status         PayrollRunStatus @default(DRAFT)
  employeeCount  Int              @default(0)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, periodStart])
}

model FieldVisit {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assigneeUserId String
  assignee       User             @relation("FieldVisitAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  clientName     String
  locationLabel  String?
  plannedAt      DateTime?
  status         FieldVisitStatus @default(PLANNED)
  purpose        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  checkIns       FieldCheckIn[]

  @@index([organizationId, assigneeUserId])
}

model FieldCheckIn {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitId        String?
  visit          FieldVisit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)
  checkedInAt    DateTime     @default(now())
  geoLat         Float
  geoLng         Float
  accuracyM      Float?
  clientName     String?
  activityNote   String?
  photoUrl       String?

  @@index([organizationId, userId, checkedInAt])
}

model JobOpening {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  department     TaskDepartment?
  location       String?
  description    String?
  isOpen         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  candidates     Candidate[]

  @@index([organizationId, isOpen])
}

model Candidate {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobOpeningId   String?
  jobOpening     JobOpening?    @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)
  fullName       String
  email          String?
  phone          String?
  stage          CandidateStage @default(APPLIED)
  source         String?
  notes          String?
  ownerUserId    String?
  owner          User?          @relation("CandidateOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  documents      CandidateDocument[]

  @@index([organizationId, stage])
}

model CandidateDocument {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  label       String
  fileUrl     String?
  uploadedAt  DateTime  @default(now())

  @@index([candidateId])
}

model FmsForm {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         FmsFormStatus    @default(DRAFT)
  createdById    String
  createdBy      User             @relation("FmsFormCreator", fields: [createdById], references: [id], onDelete: Cascade)
  fields         FmsFormField[]
  template       FmsTemplate?
  flowDesign     FmsFlowDesign?
  submissions    FmsFormSubmission[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, status])
}

model FmsFlowDesign {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         FmsDesignStatus @default(DRAFT)
  steps          Json            @default("[]")
  alertConfig    Json            @default("{}")
  holidayDates   Json            @default("[]")
  formId         String?         @unique
  form           FmsForm?        @relation(fields: [formId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User            @relation("FmsFlowDesignCreator", fields: [createdById], references: [id], onDelete: Cascade)
  submittedAt    DateTime?
  approvedById   String?
  approvedBy     User?           @relation("FmsFlowDesignApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, status])
}

model FmsFormField {
  id          String           @id @default(cuid())
  formId      String
  form        FmsForm          @relation(fields: [formId], references: [id], onDelete: Cascade)
  sortOrder   Int              @default(0)
  label       String
  fieldKey    String
  fieldType   FmsFormFieldType
  required    Boolean          @default(false)
  options     Json             @default("[]")
  placeholder String?
  helpText    String?

  @@unique([formId, fieldKey])
  @@index([formId, sortOrder])
}

model FmsTemplate {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formId         String            @unique
  form           FmsForm           @relation(fields: [formId], references: [id], onDelete: Cascade)
  name           String
  status         FmsTemplateStatus @default(DRAFT)
  holidayDates   Json              @default("[]")
  alertConfig    Json              @default("{}")
  createdById    String
  createdBy      User              @relation("FmsTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  steps          FmsTemplateStep[]
  instances      FmsInstance[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, status])
}

model FmsTemplateStep {
  id                 String        @id @default(cuid())
  templateId         String
  template           FmsTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder          Int           @default(0)
  stepName           String
  roleLabel          String?
  instructions       String?
  defaultOwnerUserId String?
  defaultOwner       User?         @relation("FmsStepDefaultOwner", fields: [defaultOwnerUserId], references: [id], onDelete: SetNull)
  slaType            FmsSlaType    @default(NONE)
  slaConfig          Json          @default("{}")
  allowMarkDone      Boolean       @default(true)
  allowUpload        Boolean       @default(false)
  allowNotes         Boolean       @default(true)
  captureFields      Json          @default("[]")
  stepStates         FmsStepState[]

  @@index([templateId, sortOrder])
}

model FmsFormSubmission {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formId         String
  form           FmsForm      @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedById  String
  submittedBy    User         @relation("FmsFormSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  values         Json         @default("{}")
  instance       FmsInstance?
  createdAt      DateTime     @default(now())

  @@index([organizationId, formId])
  @@index([formId, createdAt])
}

model FmsInstance {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId     String
  template       FmsTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissionId   String?           @unique
  submission     FmsFormSubmission?  @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  referenceLabel String?
  status         FmsInstanceStatus @default(ACTIVE)
  stepStates     FmsStepState[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([templateId, createdAt])
}

model FmsStepState {
  id                String            @id @default(cuid())
  instanceId        String
  instance          FmsInstance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId            String
  step              FmsTemplateStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  ownerUserId       String?
  owner             User?             @relation("FmsStepOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  plannedAt         DateTime?
  actualAt          DateTime?
  status            FmsStepStatus     @default(PENDING)
  delayMinutes      Int?
  completedByUserId String?
  completedBy       User?             @relation("FmsStepCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  notes             String?
  completionValues  Json              @default("{}")
  whatsappAssignSentAt    DateTime?
  whatsappDueSoonSentAt   DateTime?
  whatsappSameDaySentAt   DateTime?
  whatsappOverdueSentAt   DateTime?
  attachments       FmsStepAttachment[]

  @@unique([instanceId, stepId])
  @@index([instanceId, status])
  @@index([ownerUserId, status])
}

model FmsStepAttachment {
  id           String       @id @default(cuid())
  stepStateId  String
  stepState    FmsStepState @relation(fields: [stepStateId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User         @relation("FmsStepAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  fileSize     Int
  data         Bytes
  createdAt    DateTime     @default(now())

  @@index([stepStateId])
}
