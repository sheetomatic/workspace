  leadId         String
  lead           InboundLead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  paymentType    LeadPaymentType
  receivedAmount Decimal           @db.Decimal(14, 2)
  receivedDate   DateTime
  paymentMethod  LeadPaymentMethod
  notes          String?
