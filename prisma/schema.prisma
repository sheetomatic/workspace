  reviewedApprovals    WorkspaceApproval[]      @relation("ApprovalReviewer")
  assignedAttention    WorkspaceAttentionItem[]
  assignedFollowUps    WorkspaceFollowUp[]      @relation("FollowUpAssignee")
  assignedTasks        DelegatedTask[]          @relation("TaskAssignee")
  createdTasks         DelegatedTask[]          @relation("TaskCreator")
  verifiedTasks        DelegatedTask[]          @relation("TaskVerifier")
  taskAttachments      TaskAttachment[]         @relation("TaskAttachmentUploader")
