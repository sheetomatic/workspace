enum ChecklistTeam {
  ACCOUNTS
  HR
  MAINTENANCE
  QUALITY
  STORE
  GENERAL
}

enum ChecklistFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ChecklistOccurrenceStatus {
  PENDING
  DONE
  OVERDUE
}

enum ChecklistReferenceKind {
  WEB
  YOUTUBE
  SHARED
}

model ChecklistTemplate {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  instructions     String?
  team             ChecklistTeam      @default(GENERAL)
  frequency        ChecklistFrequency
  dueMonthDay      Int?
  dueWeekday       Int?
  dueMonth         Int?
  anchorDate       DateTime?
  dueHour          Int                @default(18)
  dueMinute        Int                @default(0)
  assigneeUserId   String
  assignee         User               @relation("ChecklistTemplateAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  createdById      String
  createdBy        User               @relation("ChecklistTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  isActive         Boolean            @default(true)
  remindViaEmail   Boolean            @default(true)
  references       ChecklistReference[]
  occurrences      ChecklistOccurrence[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId, isActive])
  @@index([organizationId, team])
  @@index([organizationId, assigneeUserId])
}

model ChecklistReference {
  id         String                 @id @default(cuid())
  templateId String
  template   ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  kind       ChecklistReferenceKind
  label      String
  href       String
  note       String?
  sortOrder  Int                    @default(0)

  @@index([templateId])
}

model ChecklistOccurrence {
  id                  String                    @id @default(cuid())
  organizationId      String
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId          String
  template            ChecklistTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  assigneeUserId      String
  assignee            User                      @relation("ChecklistOccurrenceAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  seriesKey           String
  plannedAt           DateTime
  actualAt            DateTime?
  delayMinutes        Int?
  status              ChecklistOccurrenceStatus @default(PENDING)
  notes               String?
  completedById       String?
  completedBy         User?                     @relation("ChecklistOccurrenceCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  emailReminderSentAt DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([templateId, seriesKey])
  @@index([organizationId, assigneeUserId, status])
  @@index([organizationId, plannedAt])
  @@index([organizationId, status, plannedAt])
}

