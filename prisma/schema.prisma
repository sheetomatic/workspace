  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, status])
}

model ImsVendor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  gstin          String?
  paymentTerms   String?
  leadTimeDays   Int?
  notes          String?
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  customValues   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

model ImsCustomField {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entity         ImsFormEntity
  key            String
  label          String
  fieldType      ImsCustomFieldType
  options        String[]
  required       Boolean            @default(false)
  helpText       String?
  sortOrder      Int                @default(0)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, entity, key])
  @@index([organizationId, entity, isActive])
}

model ImsFieldSetting {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entity         ImsFormEntity
  fieldKey       String
  label          String?
  hidden         Boolean       @default(false)
  sortOrder      Int           @default(0)

  @@unique([organizationId, entity, fieldKey])
}

enum ChecklistTeam {
  ACCOUNTS
  HR
  MAINTENANCE
  QUALITY
  STORE
  GENERAL
}

enum ChecklistFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ChecklistOccurrenceStatus {
  PENDING
  DONE
  OVERDUE
}

enum ChecklistReferenceKind {
  WEB
  YOUTUBE
  SHARED
}

model ChecklistTemplate {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  instructions     String?
  team             ChecklistTeam      @default(GENERAL)
  frequency        ChecklistFrequency
  dueMonthDay      Int?
  dueWeekday       Int?
  dueMonth         Int?
  anchorDate       DateTime?
  dueHour          Int                @default(18)
  dueMinute        Int                @default(0)
  assigneeUserId   String
  assignee         User               @relation("ChecklistTemplateAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  createdById      String
  createdBy        User               @relation("ChecklistTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  isActive         Boolean            @default(true)
  remindViaEmail   Boolean            @default(true)
  references       ChecklistReference[]
  occurrences      ChecklistOccurrence[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId, isActive])
  @@index([organizationId, team])
  @@index([organizationId, assigneeUserId])
}

model ChecklistReference {
  id         String                 @id @default(cuid())
  templateId String
  template   ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  kind       ChecklistReferenceKind
  label      String
  href       String
  note       String?
  sortOrder  Int                    @default(0)

  @@index([templateId])
}

model ChecklistOccurrence {
  id                  String                    @id @default(cuid())
  organizationId      String
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId          String
  template            ChecklistTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  assigneeUserId      String
  assignee            User                      @relation("ChecklistOccurrenceAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  seriesKey           String
  plannedAt           DateTime
  actualAt            DateTime?
  delayMinutes        Int?
  status              ChecklistOccurrenceStatus @default(PENDING)
  notes               String?
  completedById       String?
  completedBy         User?                     @relation("ChecklistOccurrenceCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  emailReminderSentAt DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([templateId, seriesKey])
  @@index([organizationId, assigneeUserId, status])
  @@index([organizationId, plannedAt])
  @@index([organizationId, status, plannedAt])
}

enum LeadSourceChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  GOOGLE_SHEETS
  MANUAL
  API
}

enum InboundLeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  WON
  LOST
}

enum LeadConnectionSyncStatus {
  IDLE
  SYNCING
  ERROR
}

model LeadIngestConnection {
  id               String                   @id @default(cuid())
  organizationId   String
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel          LeadSourceChannel
  label            String
  enabled          Boolean                  @default(false)
  config           Json                     @default("{}")
  ingestSecretHash String?
  lastSyncAt       DateTime?
  lastSyncError    String?
  syncStatus       LeadConnectionSyncStatus @default(IDLE)
  leads            InboundLead[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([organizationId, channel])
  @@index([organizationId, enabled])
}

model InboundLead {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectionId   String?
  connection     LeadIngestConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  channel        LeadSourceChannel
  externalId     String?
  name           String?
  phone          String?
  email          String?
  city           String?
  requirement    String?
  sourceDetail   String?
  status         InboundLeadStatus    @default(NEW)
  rawPayload     Json?
  fmsInstanceId  String?              @unique
  fmsInstance    FmsInstance?         @relation(fields: [fmsInstanceId], references: [id], onDelete: SetNull)
  waContactId    String?              @unique
  waContact      WaContact?           @relation(fields: [waContactId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?                @relation("InboundLeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  nextFollowUpAt DateTime?
  followUps      InboundLeadFollowUp[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@index([organizationId, nextFollowUpAt])
  @@index([organizationId, assignedToId])
}

model InboundLeadFollowUp {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId          String
  lead            InboundLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeUserId  String?
  assignee        User?        @relation("InboundLeadFollowUpAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  scheduledAt     DateTime
  completedAt     DateTime?
  notes           String?
  createdByUserId String?
  createdBy       User?        @relation("InboundLeadFollowUpCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, scheduledAt])
  @@index([leadId])
}
