  code           String
  name           String
  description    String?
  uom            String       @default("pcs")
  category       String?
  itemType       ImsItemType  @default(RAW_MATERIAL)
  abcClass       ImsAbcClass  @default(C)
  unitCost       Decimal      @default(0) @db.Decimal(18, 4)
  minQty         Decimal      @default(0) @db.Decimal(18, 4)
  reorderQty     Decimal      @default(0) @db.Decimal(18, 4)
  maxQty         Decimal      @default(0) @db.Decimal(18, 4)
  qcOnReceipt    ImsQcPolicy  @default(OPTIONAL)
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
