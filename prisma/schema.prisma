  whatsappTemplates    WhatsAppTemplate[]       @relation("WhatsAppTemplateCreator")
  assignedWaContacts   WaContact[]              @relation("WaContactAssignee")
  assignedWaFollowUps  WaContactFollowUp[]      @relation("WaFollowUpAssignee")
  createdWaFollowUps   WaContactFollowUp[]      @relation("WaFollowUpCreator")
  waMessagesSent       WaMessage[]              @relation("WaMessageSender")
  aiKnowledgeCreated   AiKnowledgeItem[]        @relation("AiKnowledgeCreator")
  attendanceRecords    AttendanceRecord[]       @relation("AttendanceUser")
  attendanceMarked     AttendanceRecord[]       @relation("AttendanceMarker")
  attendanceVerified   AttendanceRecord[]       @relation("AttendanceVerifier")
  attendanceExceptionRequests AttendanceExceptionRequest[] @relation("AttendanceExceptionRequester")
  attendanceExceptionReviews  AttendanceExceptionRequest[] @relation("AttendanceExceptionReviewer")
  leaveRequests        LeaveRequest[]           @relation("LeaveRequester")
  leaveReviews         LeaveRequest[]           @relation("LeaveReviewer")
  hrSwapRequests       HrSwapRequest[]          @relation("HrSwapRequester")
  hrSwapReviews        HrSwapRequest[]          @relation("HrSwapReviewer")
  payrollLines         PayrollLine[]            @relation("PayrollLineEmployee")
  employeeProfiles     EmployeeProfile[]        @relation("EmployeeProfileUser")
  employeeDocumentsUploaded EmployeeDocument[]  @relation("EmployeeDocumentUploader")
  fieldCheckIns        FieldCheckIn[]
  fieldCheckInAttachmentsUploaded FieldCheckInAttachment[] @relation("FieldCheckInAttachmentUploader")
  fieldVisitsAssigned  FieldVisit[]             @relation("FieldVisitAssignee")
  fieldLocationPings   FieldLocationPing[]
  candidatesOwned      Candidate[]              @relation("CandidateOwner")
  legalCaseDocuments   LegalCaseDocument[]      @relation("LegalCaseDocumentUploader")
  notificationSettings UserNotificationSettings[]
  taskAiUsageEvents    TaskAiUsageEvent[]
  fmsFormsCreated      FmsForm[]                @relation("FmsFormCreator")
  fmsTemplatesCreated  FmsTemplate[]            @relation("FmsTemplateCreator")
  fmsTemplatesEa       FmsTemplate[]            @relation("FmsTemplateEa")
  fmsFormSubmissions   FmsFormSubmission[]      @relation("FmsFormSubmitter")
  fmsStepsOwned        FmsStepState[]           @relation("FmsStepOwner")
  fmsStepsCompleted    FmsStepState[]           @relation("FmsStepCompleter")
  fmsStepDefaultOwner  FmsTemplateStep[]        @relation("FmsStepDefaultOwner")
  fmsStepAttachments   FmsStepAttachment[]      @relation("FmsStepAttachmentUploader")
  fmsFlowDesignsCreated FmsFlowDesign[]         @relation("FmsFlowDesignCreator")
  fmsFlowDesignsApproved FmsFlowDesign[]        @relation("FmsFlowDesignApprover")
  fmsAuditEvents         FmsAuditEvent[]        @relation("FmsAuditActor")
  appNotifications       UserAppNotification[]
  checklistTemplatesCreated ChecklistTemplate[] @relation("ChecklistTemplateCreator")
  checklistTemplatesOwned   ChecklistTemplate[] @relation("ChecklistTemplateAssignee")
  checklistOccurrencesOwned ChecklistOccurrence[] @relation("ChecklistOccurrenceAssignee")
  checklistOccurrencesDone  ChecklistOccurrence[] @relation("ChecklistOccurrenceCompleter")
  imsMovementsCreated    ImsStockMovement[]    @relation("ImsMovementCreator")
  imsRequisitionsRequested ImsMaterialRequisition[] @relation("ImsRequisitionRequester")
  imsRequisitionsApproved  ImsMaterialRequisition[] @relation("ImsRequisitionApprover")
  imsIndentsCreated        ImsIndent[]             @relation("ImsIndentCreator")
  imsIndentsApproved       ImsIndent[]             @relation("ImsIndentApprover")
  imsPurchaseOrdersCreated ImsPurchaseOrder[]      @relation("ImsPurchaseOrderCreator")
  imsPurchaseOrdersApproved ImsPurchaseOrder[]     @relation("ImsPurchaseOrderApprover")
  imsPurchaseBillsCreated  ImsPurchaseBill[]       @relation("ImsPurchaseBillCreator")
  imsPhysicalStockCountsCreated ImsPhysicalStockCount[] @relation("ImsPhysicalStockCountCreator")
  imsGatePassesCreated     ImsGatePass[]           @relation("ImsGatePassCreator")
  imsGatePassesIssued      ImsGatePass[]           @relation("ImsGatePassIssuer")
  orgExpenseEntriesCreated OrgExpenseEntry[]       @relation("OrgExpenseEntryCreator")
  imsQcInspected         ImsQcInspection[]     @relation("ImsQcInspector")
  imsAttachmentsUploaded ImsAttachment[]       @relation("ImsAttachmentUploader")
  assignedInboundLeads         InboundLead[]         @relation("InboundLeadAssignee")
  createdInboundLeads          InboundLead[]         @relation("InboundLeadCreator")
  assignedInboundLeadFollowUps InboundLeadFollowUp[] @relation("InboundLeadFollowUpAssignee")
  createdInboundLeadFollowUps  InboundLeadFollowUp[] @relation("InboundLeadFollowUpCreator")
  inboundLeadActivities        InboundLeadActivity[] @relation("InboundLeadActivityCreator")
  createdInboundLeadQuotations InboundLeadQuotation[] @relation("InboundLeadQuotationCreator")
