  serviceCategory String
  subCategory     String
  quantity        Int                  @default(1)
  unitPrice       Decimal              @db.Decimal(14, 2)
  lineTotal       Decimal              @db.Decimal(14, 2)

  @@index([quotationId])
}

model SalesOrder {
  id                 String            @id @default(cuid())
  organizationId     String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId             String
  lead               InboundLead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  quotationId        String
  quotation          InboundLeadQuotation @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  orderNumber        String
  status             SalesOrderStatus  @default(DRAFT)
  lineItems          Json              @default("[]")
  shortageSnapshot   Json?
  dispatchShareToken String?           @unique
  fmsInstances       FmsInstance[]
  fmsLinks           SalesOrderFmsLink[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@index([leadId])
  @@index([quotationId])
}

model SalesOrderFmsLink {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrderId   String
  salesOrder     SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  fmsInstanceId  String            @unique
  fmsInstance    FmsInstance       @relation(fields: [fmsInstanceId], references: [id], onDelete: Cascade)
