model LeadIngestConnection {
  id               String                   @id @default(cuid())
  organizationId   String
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel          LeadSourceChannel
  label            String
  enabled          Boolean                  @default(false)
  config           Json                     @default("{}")
  ingestSecretHash String?
  lastSyncAt       DateTime?
  lastSyncError    String?
  syncStatus       LeadConnectionSyncStatus @default(IDLE)
  leads            InboundLead[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([organizationId, channel])
  @@index([organizationId, enabled])
}

model InboundLead {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectionId   String?
  connection     LeadIngestConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  channel        LeadSourceChannel
  externalId     String?
  name           String?
  phone          String?
  email          String?
  city           String?
  requirement    String?
  sourceDetail   String?
  company        String?
  address        String?
  zipCode        String?
  category       String?
  pipeValue      Decimal?             @db.Decimal(14, 2)
  quotationValue Decimal?             @db.Decimal(14, 2)
  discussionNotes String?
  meetingNotes   String?
  callingStatus  LeadCallingStatus    @default(NOT_CALLED)
  projectStatus  LeadProjectStatus    @default(NOT_STARTED)
  aiSuggestedStatus InboundLeadStatus?
  status         InboundLeadStatus    @default(NEW)
  score          Int?
  temperature    LeadTemperature?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  campaign       String?
  landingPage    String?
  /** Expected close date for pipeline forecast (PDF Phase 13). */
  expectedCloseAt DateTime?
  /** Win probability 0–100; null = use stage default. */
  winProbability Int?
  archivedAt     DateTime?
  /** Soft-merge: secondary lead points at the surviving primary. */
  mergedIntoId   String?
  mergedInto     InboundLead?         @relation("InboundLeadMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom     InboundLead[]        @relation("InboundLeadMerge")
  /** Cached GPT qualification summary (need / budget / next action). */
  aiSummary      String?
  aiSummaryAt    DateTime?
  rawPayload     Json?
  fmsInstanceId  String?              @unique
  fmsInstance    FmsInstance?         @relation(fields: [fmsInstanceId], references: [id], onDelete: SetNull)
  waContactId    String?              @unique
  waContact      WaContact?           @relation(fields: [waContactId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?                @relation("InboundLeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy      User?                @relation("InboundLeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  nextFollowUpAt DateTime?
  capturedAt     DateTime?
  /** Set when a team member edits the lead in CRM — not updated on passive sheet sync. */
  modifiedAt     DateTime?
  followUps      InboundLeadFollowUp[]
  activities     InboundLeadActivity[]
  payments       InboundLeadPayment[]
  quotations     InboundLeadQuotation[]
  salesOrders    SalesOrder[]
  offeredServices InboundLeadOfferedService[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@index([organizationId, nextFollowUpAt])
  @@index([organizationId, assignedToId])
  @@index([organizationId, capturedAt])
  @@index([organizationId, category])
  @@index([organizationId, modifiedAt])
  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@index([organizationId, archivedAt])
  @@index([organizationId, mergedIntoId])
}

model InboundLeadActivity {
