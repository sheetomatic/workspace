model InboundLeadQuotation {
  id                      String                   @id @default(cuid())
  organizationId          String
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId                  String
  lead                    InboundLead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  quotationNumber         String
  requestType             QuotationRequestType     @default(PROPOSAL)
  status                  QuotationStatus          @default(DRAFT)
  revisionNumber          Int                      @default(1)
  revisedFromQuotationId  String?
  revisedFrom             InboundLeadQuotation?    @relation("QuotationRevisions", fields: [revisedFromQuotationId], references: [id], onDelete: SetNull)
  revisions               InboundLeadQuotation[]   @relation("QuotationRevisions")
  shareToken              String?                  @unique
  company                 String?
  address                 String?
  zipCode                 String?
  quotationDate           DateTime
  projectStartDate        DateTime?
  durationDays            Int?
  endDate                 DateTime?
  subtotal                Decimal                  @db.Decimal(14, 2)
  taxAmount               Decimal?                 @db.Decimal(14, 2)
  totalAmount             Decimal                  @db.Decimal(14, 2)
  advanceRequired         Decimal?                 @db.Decimal(14, 2)
  scopeNotes              String?
  paymentTerms            String?
  notes                   String?
  sentAt                  DateTime?
  lockedAt                DateTime?
