/// Owner ops cost tracker — API, team, office, vehicles, subscriptions.
enum OrgExpenseCategory {
  API_CURSOR
  API_OPENAI
  API_WHATSAPP
  MARKETING
  SALARY
  OFFICE_RENT
  MOBILE
  ELECTRICITY
  SUBSCRIPTION_NETFLIX
  SUBSCRIPTION_PRIME
  SUBSCRIPTION_OTHER
  PHONE_NUMBERS_PLAN
  FUEL
  VEHICLE_CAR
  VEHICLE_BIKE
  VEHICLE_SCOOTY
  EMI
  SCHOOL
  GROCERY
  VEGETABLES
  DRINKS
  MEAT
  KIDS_DAILY
  INTERNET_WIFI
  OTHER
}

enum OrgExpenseRecurrence {
  ONE_TIME
  MONTHLY
}

model OrgExpenseEntry {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       OrgExpenseCategory
  title          String
  amount         Decimal             @db.Decimal(14, 2)
  currency       String              @default("INR")
  expenseDate    DateTime
  recurrence     OrgExpenseRecurrence @default(ONE_TIME)
  /// For PHONE_NUMBERS_PLAN — active numbers on plan this month
  quantity       Int?
  /// For EMI — asset under EMI (car, home, laptop, etc.)
  assetLabel     String?
  vendor         String?
  notes          String?
  createdById    String
  createdBy      User                @relation("OrgExpenseEntryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, expenseDate])
  @@index([organizationId, category])
}

/// Marketing 1:1 courses enrollment — platform-level (no tenant org).
enum CourseCohort {
  MON_FRI
  TUE_SAT
}

enum CourseEnrollmentStatus {
  PAYMENT_PENDING
  CONFIRMED
  CANCELLED
}

enum TrainingSlotStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum TrainingFrequency {
  WEEKLY
  BIWEEKLY
}

model CourseEnrollment {
  id               String                 @id @default(cuid())
  name             String
  phone            String
  email            String
  amountInr        Int                    @default(35000)
  cohort           CourseCohort
  status           CourseEnrollmentStatus @default(PAYMENT_PENDING)
  slotNotes        String?
  /** First training session date (IST calendar day) once slots are booked. */
  programStartDate DateTime?
  /** Optional Google Meet / Zoom link shared on all sessions. */
  meetUrl          String?
  /** How often cohort days repeat. */
  frequency        TrainingFrequency      @default(WEEKLY)
  /** Session start time in Asia/Kolkata, HH:mm (24h). */
  sessionTimeIst   String                 @default("08:30")
  /** Session length in minutes. */
  sessionDurationMin Int                  @default(90)
  /** Total live sessions to generate. */
  totalSessions    Int                    @default(24)
  /** Public token for /courses/book-slots?token=… */
  bookingToken     String?                @unique
  /** Optional CRM link when booked from workspace lead. */
  organizationId   String?
  inboundLeadId    String?
  confirmedAt      DateTime?
  confirmedById    String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  slots            TrainingCourseSlot[]

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
  @@index([organizationId, inboundLeadId])
  @@index([bookingToken])
}

/// Individual 1:1 training sessions generated from cohort + program start date.
model TrainingCourseSlot {
  id             String             @id @default(cuid())
  enrollmentId   String
  enrollment     CourseEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  organizationId String?
  inboundLeadId  String?
  sessionNumber  Int
  startsAt       DateTime
  endsAt         DateTime
  title          String
  meetUrl        String?
  status         TrainingSlotStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([enrollmentId, sessionNumber])
  @@index([enrollmentId, startsAt])
  @@index([organizationId, startsAt])
  @@index([inboundLeadId, startsAt])
  @@index([status, startsAt])
}
