}

model UserNotificationSettings {
  id                 String       @id @default(cuid())
  userId             String
  organizationId     String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseDueDateAlert   Boolean      @default(true)
  caseOverdueAlert   Boolean      @default(true)
  taskDueDateAlert   Boolean      @default(true)
  taskOverdueAlert   Boolean      @default(true)
  imsReorderAlert    Boolean      @default(false)
  alertDaysBefore    Int          @default(1)
  alertViaEmail      Boolean      @default(true)
  alertViaWhatsApp   Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id                    String          @id @default(cuid())
  email                 String
  role                  Role            @default(STAFF)
  organizationId        String
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  token                 String          @unique
  invitedById           String
  invitedBy             User            @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  /** Membership id of reporting manager (optional pre-assign). */
  reportingManagerId    String?
  department            TaskDepartment?
  designation           String?
  requireOnboarding     Boolean         @default(true)
  onboardingCompletedAt DateTime?
  expiresAt             DateTime
  acceptedAt            DateTime?
  createdAt             DateTime        @default(now())

  @@unique([email, organizationId])
  @@index([organizationId])
}

model Membership {
  id                 String               @id @default(cuid())
  role               Role                 @default(STAFF)
  department         TaskDepartment?
  designation        String?
  isDepartmentHead   Boolean              @default(false)
  reportingManagerId String?
  reportingManager   Membership?          @relation("MembershipReportsTo", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      Membership[]         @relation("MembershipReportsTo")
  attendanceWorkMode AttendanceWorkMode   @default(OFFICE)
  /** FIXED_SITE enforces primary/selected site fence; FLEXIBLE never blocks on fence. */
  locationMode       EmployeeLocationMode @default(FIXED_SITE)
  primarySiteId      String?
  primarySite        HrWorkSite?          @relation("MembershipPrimarySite", fields: [primarySiteId], references: [id], onDelete: SetNull)
  /** Assigned shift timing; null falls back to org default work hours. */
  shiftId            String?
  shift              HrShift?             @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  /** Preferred weekly off: 0=Sun … 6=Sat. Null = Sunday (0). */
  weeklyOffDay       Int?
  geoFenceRequired   Boolean              @default(false)
  faceRequired       Boolean              @default(false)
  staffCode          String?
  /** Monthly CTC / gross used for attendance-based payroll (INR). */
  monthlySalary      Decimal?             @db.Decimal(14, 2)
  dateOfJoining      DateTime?
  modules            WorkspaceModule[]    @default([])
  /** Per-user sidebar/home visibility: { mode, visibleIds }. */
  workspacePrefs     Json?
  userId             String
  organizationId     String
  deactivatedAt      DateTime?
  lastTaskDigestAt     DateTime?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeProfile EmployeeProfile?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, isDepartmentHead])
  @@index([reportingManagerId])
  @@index([primarySiteId])
  @@index([shiftId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AttendanceMethod {
  WEB
  MOBILE
  GEO
  BIOMETRIC
  FACE
}

enum AttendanceDayStatus {
  PRESENT
  ABSENT
  HALF_DAY
  SHORT_LEAVE
  ON_LEAVE
  HOLIDAY
}

/** White-collar (standard) vs Blue-collar (OT-eligible). */
enum EmployeeCollarCategory {
  WHITE
  BLUE
}

/** Self punch starts PENDING; manager mark or approve → VERIFIED. */
enum AttendanceVerifyStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AttendanceWorkMode {
  OFFICE
  FIELD
  HYBRID
}

enum EmployeeLocationMode {
  FIXED_SITE
  FLEXIBLE
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  COMP_OFF
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceExceptionType {
  OD
  WFH
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
}

enum FieldVisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum HrSwapType {
  LEAVE_SWAP
  OFF_DAY_SWAP
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum EmployeeStatus {
  ACTIVE
  EXITED
}

enum EmployeeOnboardingStatus {
  PENDING_DOCS
  COMPLETE
  SKIPPED
}

enum EmployeeDocumentType {
  AADHAAR
  PAN
  OFFER_LETTER
  CONTRACT
  EDUCATION_QUALIFICATION
  CV
  WORK_EXPERIENCE
  NOC_RESIGNATION
  OTHER
}

model WorkspaceHrSettings {
  organizationId         String       @id
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  officeLat              Float?
  officeLng              Float?
  geoFenceRadiusM        Int          @default(200)
  workStartTime          String       @default("09:30")
  workEndTime            String       @default("18:30")
  /** Minutes after workStartTime before check-in counts as late. */
  lateGraceMinutes       Int          @default(15)
  halfDayEnabled         Boolean      @default(true)
  shortLeaveEnabled      Boolean      @default(true)
  /** Hours deducted from a full day when status is SHORT_LEAVE (payable fraction). */
  shortLeaveHours        Float        @default(2)
  faceRecognitionEnabled Boolean      @default(false)
  fieldTrackingEnabled   Boolean      @default(true)
  /** Org-enabled HR sub-modules (attendance, leave, …). Empty = all defaults for backward compat. */
  enabledHrSubModules    String[]     @default([])
  updatedAt              DateTime     @updatedAt
}

model HrWorkSite {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  lat             Float
  lng             Float
  geoFenceRadiusM Int                @default(200)
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  primaryMembers  Membership[]       @relation("MembershipPrimarySite")

  @@index([organizationId, isActive])
}

/** Named work shift (General / Morning / Night) with start/end timing. */
model HrShift {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /** Optional short code e.g. GEN, MOR, NIGHT. */
  code           String?
  startTime      String
  endTime        String
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  members        Membership[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

model HrHoliday {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  name           String
  isOptional     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

model AttendanceRecord {
  id              String                 @id @default(cuid())
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User                   @relation("AttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  siteId          String?
  site            HrWorkSite?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  workDate        DateTime               @db.Date
  checkInAt       DateTime?
  checkOutAt      DateTime?
  status          AttendanceDayStatus    @default(PRESENT)
  verifyStatus    AttendanceVerifyStatus @default(VERIFIED)
  verifiedById    String?
  verifiedBy      User?                  @relation("AttendanceVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt      DateTime?
  isLate          Boolean                @default(false)
  /** Overtime hours (Blue collar). Manager-entered or auto from checkout past workEndTime. */
  otHours         Float                  @default(0)
  method          AttendanceMethod       @default(WEB)
  geoLat          Float?
  geoLng          Float?
  geoFenceOk      Boolean?
  faceVerified    Boolean                @default(false)
  notes           String?
  markedById      String?
  markedBy        User?                  @relation("AttendanceMarker", fields: [markedById], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([organizationId, userId, workDate])
  @@index([organizationId, workDate])
  @@index([organizationId, verifyStatus])
}

model AttendanceExceptionRequest {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                     @relation("AttendanceExceptionRequester", fields: [userId], references: [id], onDelete: Cascade)
  exceptionType  AttendanceExceptionType
  startDate      DateTime                 @db.Date
  endDate        DateTime                 @db.Date
  reason         String?
  status         LeaveRequestStatus       @default(PENDING)
  reviewedById   String?
  reviewedBy     User?                    @relation("AttendanceExceptionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, userId])
}

model LeaveBalance {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  leaveType      LeaveType
  balanceDays    Float        @default(0)
  usedDays       Float        @default(0)
  year           Int
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId, leaveType, year])
}

model LeavePolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveType      LeaveType
  year           Int
  defaultDays    Float
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  @@unique([organizationId, leaveType, year])
  @@index([organizationId, year])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType      LeaveType
  startDate      DateTime           @db.Date
  endDate        DateTime           @db.Date
  days           Float
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedBy     User?              @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, userId])
}

/**
 * Swap leave day or weekly off.
 * LEAVE_SWAP: move a single-day PENDING/APPROVED leave fromDate → toDate.
 * OFF_DAY_SWAP: work on fromDate (usual off), take toDate as off (HOLIDAY + "Weekly off").
 */
model HrSwapRequest {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation("HrSwapRequester", fields: [userId], references: [id], onDelete: Cascade)
  swapType       HrSwapType
  fromDate       DateTime           @db.Date
  toDate         DateTime           @db.Date
  reason         String?
  /** Optional link to the leave being moved (LEAVE_SWAP). */
  leaveRequestId String?
  status         LeaveRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedBy     User?              @relation("HrSwapReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, userId])
}

model PayrollRun {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime         @db.Date
  periodEnd      DateTime         @db.Date
  status         PayrollRunStatus @default(DRAFT)
  employeeCount  Int              @default(0)
  totalGross     Decimal?         @db.Decimal(14, 2)
  totalNet       Decimal?         @db.Decimal(14, 2)
  notes          String?
  lines          PayrollLine[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, periodStart])
}

model PayrollLine {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payrollRunId   String
  payrollRun     PayrollRun   @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("PayrollLineEmployee", fields: [userId], references: [id], onDelete: Cascade)
  presentDays    Float        @default(0)
  leaveDays      Float        @default(0)
  absentDays     Float        @default(0)
  halfDays       Float        @default(0)
  shortLeaveDays Float        @default(0)
  payableDays    Float        @default(0)
  workingDays    Float        @default(0)
  otHours        Float        @default(0)
  otPay          Decimal      @default(0) @db.Decimal(14, 2)
  monthlySalary  Decimal      @db.Decimal(14, 2)
  earnedSalary   Decimal      @db.Decimal(14, 2)
  deductions     Decimal      @default(0) @db.Decimal(14, 2)
  netPay         Decimal      @db.Decimal(14, 2)
  notes          String?

  @@unique([payrollRunId, userId])
  @@index([organizationId, payrollRunId])
}

/** HR employee master — 1:1 with Membership. Job title/dept/DOJ/gross live on Membership. */
model EmployeeProfile {
  id                 String                   @id @default(cuid())
  organizationId     String
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membershipId       String                   @unique
  membership         Membership               @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  userId             String
  user               User                     @relation("EmployeeProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  employeeCode       String
  employmentType     EmploymentType           @default(FULL_TIME)
  status             EmployeeStatus           @default(ACTIVE)
  onboardingStatus   EmployeeOnboardingStatus @default(COMPLETE)
  /** WHITE = standard (no OT). BLUE = overtime-eligible. */
  collarCategory     EmployeeCollarCategory   @default(WHITE)
  /** Optional explicit OT hourly rate; else derived from monthlySalary / monthly hours. */
  hourlyRate         Decimal?                 @db.Decimal(14, 2)
  educationSummary   String?
  experienceSummary  String?
  phone              String?
  emergencyContact   String?
  address            String?
  dateOfBirth        DateTime?                @db.Date
  gender             String?
  /** Full PAN — ADMIN+ read only in queries. */
  pan                String?
  /** Full Aadhaar string — ADMIN+ read only; prefer aadhaarLast4 for display. */
  aadhaar            String?
  aadhaarLast4       String?
  basic              Decimal?                 @db.Decimal(14, 2)
  hra                Decimal?                 @db.Decimal(14, 2)
  specialAllowance   Decimal?                 @db.Decimal(14, 2)
  esiApplicable      Boolean                  @default(false)
  esiNumber          String?
  pfApplicable       Boolean                  @default(false)
  uan                String?
  pfNumber           String?
  /** OLD | NEW — informational for v1. */
  taxRegime          String?
  /** Fixed monthly TDS amount (INR) for slip deductions. */
  tdsMonthly         Decimal?                 @db.Decimal(14, 2)
  bankName           String?
  bankAccountNumber  String?
  ifsc               String?
  documents          EmployeeDocument[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([organizationId, employeeCode])
  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([organizationId, onboardingStatus])
}

model EmployeeDocument {
  id                String               @id @default(cuid())
  organizationId    String
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeProfileId String
  employeeProfile   EmployeeProfile      @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  docType           EmployeeDocumentType @default(OTHER)
  fileName          String
  mimeType          String
  fileSize          Int
  data              Bytes
  uploadedById      String
  uploadedBy        User                 @relation("EmployeeDocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  uploadedAt        DateTime             @default(now())

  @@index([employeeProfileId])
  @@index([organizationId, employeeProfileId])
}

model FieldVisit {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assigneeUserId String
  assignee       User             @relation("FieldVisitAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  clientName     String
  locationLabel  String?
  /** Optional visit geofence centre + radius (metres). */
  geoLat         Float?
  geoLng         Float?
  radiusM        Int?
  plannedAt      DateTime?
  status         FieldVisitStatus @default(PLANNED)
  purpose        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  checkIns       FieldCheckIn[]

  @@index([organizationId, assigneeUserId])
}

model FieldCheckIn {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitId        String?
  visit          FieldVisit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)
  checkedInAt    DateTime     @default(now())
  geoLat         Float
  geoLng         Float
  accuracyM      Float?
  clientName     String?
  activityNote   String?
