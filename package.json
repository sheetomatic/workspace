{
  "name": "sheetomatic-redesign",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && prisma migrate deploy && NODE_OPTIONS=--max-old-space-size=8192 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed-bci": "tsx prisma/seed-bci-demo.ts",
    "db:seed-acme-ims": "tsx prisma/seed-acme-ims.ts",
    "db:sync-hingorani": "tsx prisma/sync-hingorani-sheet.ts",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/smoke",
    "test:e2e:tenant": "playwright test tests/e2e/tenant-isolation.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "googleapis": "^172.0.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
